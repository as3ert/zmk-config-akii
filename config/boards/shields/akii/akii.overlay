/*
 * AKII -- Apple Keyboard II replica
 * XIAO nRF52840 + 2x MCP23017 I2C GPIO expanders
 *
 * Hardware facts (verified against board netlist):
 *   mcp_c @ 0x20: GPA0-7 (exp pins 0-7)  = COL8..COL15
 *                 GPB7   (exp pin 15)    = COL16
 *                 GPB6   (exp pin 14)    = COL17
 *   mcp_r @ 0x24: GPA0-4 (exp pins 0-4)  = ROW0..ROW4   (A2=3V3 -> addr 0x24)
 *                 GPB7..GPB0 (15..8)     = COL0..COL7
 *
 * Scanning scheme: diodes are physically COL->ROW (QMK "COL2ROW").
 * MCP23017 has internal pull-UPS only (no pull-downs), so we scan
 * QMK-style: drive a row LOW, read columns with pull-ups, active low.
 * In ZMK terms that means diode-direction "row2col" (rows are outputs)
 * with every pin declared GPIO_ACTIVE_LOW.
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <physical_layouts.dtsi>

&xiao_i2c {
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;   /* 400 kHz, MCP23017 supports it */

    /* Two-tier kscan owns both MCP23017s over raw I2C (no gpio-controller).
     * reg = mcp_c @0x20 (COL8-17); addr-rows = mcp_r @0x24 (ROW0-4 + COL0-7). */
    kscan0: kscan_akii@20 {
        compatible = "zmk,kscan-akii-twotier";
        reg = <0x20>;
        addr-rows = <0x24>;
        idle-poll-period-ms = <25>;
        active-poll-period-ms = <5>;
        idle-timeout-ms = <750>;
        debounce-press-ms = <5>;
        debounce-release-ms = <5>;
    };
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <18>;
        rows = <5>;
        /* visual order, matches the keymap row by row */
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) RC(1,16) RC(1,17)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12)          RC(2,14) RC(2,15) RC(2,16) RC(2,17)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)          RC(3,12)          RC(3,14) RC(3,15) RC(3,16) RC(4,17)
RC(4,0) RC(4,1) RC(4,2)                 RC(4,5)                 RC(4,9) RC(4,10) RC(4,11) RC(4,12) RC(4,13)                   RC(4,15) RC(4,16)
        >;
    };

    /* Physical key positions for ZMK Studio. Coordinates (centi-keyunits,
     * 1u = 100) lifted straight from the QMK plate layout, so they match the
     * real board: 2u Delete, 2.25u Return, 2.75u right Shift, 6.25u space,
     * 2u keypad-0, 2u-tall keypad Enter. Key order MUST match default_transform. */
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "AKII";
        transform = <&default_transform>;
        keys
            //                       w   h     x    y  rot rx ry
            /* row 0 */
            = <&key_physical_attrs 100 100     0    0    0  0  0>   /* ESC   */
            , <&key_physical_attrs 100 100   100    0    0  0  0>   /* 1     */
            , <&key_physical_attrs 100 100   200    0    0  0  0>   /* 2     */
            , <&key_physical_attrs 100 100   300    0    0  0  0>   /* 3     */
            , <&key_physical_attrs 100 100   400    0    0  0  0>   /* 4     */
            , <&key_physical_attrs 100 100   500    0    0  0  0>   /* 5     */
            , <&key_physical_attrs 100 100   600    0    0  0  0>   /* 6     */
            , <&key_physical_attrs 100 100   700    0    0  0  0>   /* 7     */
            , <&key_physical_attrs 100 100   800    0    0  0  0>   /* 8     */
            , <&key_physical_attrs 100 100   900    0    0  0  0>   /* 9     */
            , <&key_physical_attrs 100 100  1000    0    0  0  0>   /* 0     */
            , <&key_physical_attrs 100 100  1100    0    0  0  0>   /* -     */
            , <&key_physical_attrs 100 100  1200    0    0  0  0>   /* =     */
            , <&key_physical_attrs 200 100  1300    0    0  0  0>   /* BSPC  */
            , <&key_physical_attrs 100 100  1600    0    0  0  0>   /* Clear */
            , <&key_physical_attrs 100 100  1700    0    0  0  0>   /* KP=   */
            , <&key_physical_attrs 100 100  1800    0    0  0  0>   /* KP/   */
            , <&key_physical_attrs 100 100  1900    0    0  0  0>   /* KP*   */
            /* row 1 */
            , <&key_physical_attrs 150 100     0  100    0  0  0>   /* TAB   */
            , <&key_physical_attrs 100 100   150  100    0  0  0>   /* Q     */
            , <&key_physical_attrs 100 100   250  100    0  0  0>   /* W     */
            , <&key_physical_attrs 100 100   350  100    0  0  0>   /* E     */
            , <&key_physical_attrs 100 100   450  100    0  0  0>   /* R     */
            , <&key_physical_attrs 100 100   550  100    0  0  0>   /* T     */
            , <&key_physical_attrs 100 100   650  100    0  0  0>   /* Y     */
            , <&key_physical_attrs 100 100   750  100    0  0  0>   /* U     */
            , <&key_physical_attrs 100 100   850  100    0  0  0>   /* I     */
            , <&key_physical_attrs 100 100   950  100    0  0  0>   /* O     */
            , <&key_physical_attrs 100 100  1050  100    0  0  0>   /* P     */
            , <&key_physical_attrs 100 100  1150  100    0  0  0>   /* [     */
            , <&key_physical_attrs 100 100  1250  100    0  0  0>   /* ]     */
            , <&key_physical_attrs 150 100  1350  100    0  0  0>   /* \     */
            , <&key_physical_attrs 100 100  1600  100    0  0  0>   /* KP7   */
            , <&key_physical_attrs 100 100  1700  100    0  0  0>   /* KP8   */
            , <&key_physical_attrs 100 100  1800  100    0  0  0>   /* KP9   */
            , <&key_physical_attrs 100 100  1900  100    0  0  0>   /* KP-   */
            /* row 2 */
            , <&key_physical_attrs 175 100     0  200    0  0  0>   /* CAPS  */
            , <&key_physical_attrs 100 100   175  200    0  0  0>   /* A     */
            , <&key_physical_attrs 100 100   275  200    0  0  0>   /* S     */
            , <&key_physical_attrs 100 100   375  200    0  0  0>   /* D     */
            , <&key_physical_attrs 100 100   475  200    0  0  0>   /* F     */
            , <&key_physical_attrs 100 100   575  200    0  0  0>   /* G     */
            , <&key_physical_attrs 100 100   675  200    0  0  0>   /* H     */
            , <&key_physical_attrs 100 100   775  200    0  0  0>   /* J     */
            , <&key_physical_attrs 100 100   875  200    0  0  0>   /* K     */
            , <&key_physical_attrs 100 100   975  200    0  0  0>   /* L     */
            , <&key_physical_attrs 100 100  1075  200    0  0  0>   /* ;     */
            , <&key_physical_attrs 100 100  1175  200    0  0  0>   /* '     */
            , <&key_physical_attrs 225 100  1275  200    0  0  0>   /* RET   */
            , <&key_physical_attrs 100 100  1600  200    0  0  0>   /* KP4   */
            , <&key_physical_attrs 100 100  1700  200    0  0  0>   /* KP5   */
            , <&key_physical_attrs 100 100  1800  200    0  0  0>   /* KP6   */
            , <&key_physical_attrs 100 100  1900  200    0  0  0>   /* KP+   */
            /* row 3 */
            , <&key_physical_attrs 225 100     0  300    0  0  0>   /* LSHFT */
            , <&key_physical_attrs 100 100   225  300    0  0  0>   /* Z     */
            , <&key_physical_attrs 100 100   325  300    0  0  0>   /* X     */
            , <&key_physical_attrs 100 100   425  300    0  0  0>   /* C     */
            , <&key_physical_attrs 100 100   525  300    0  0  0>   /* V     */
            , <&key_physical_attrs 100 100   625  300    0  0  0>   /* B     */
            , <&key_physical_attrs 100 100   725  300    0  0  0>   /* N     */
            , <&key_physical_attrs 100 100   825  300    0  0  0>   /* M     */
            , <&key_physical_attrs 100 100   925  300    0  0  0>   /* ,     */
            , <&key_physical_attrs 100 100  1025  300    0  0  0>   /* .     */
            , <&key_physical_attrs 100 100  1125  300    0  0  0>   /* /     */
            , <&key_physical_attrs 275 100  1225  300    0  0  0>   /* RSHFT */
            , <&key_physical_attrs 100 100  1600  300    0  0  0>   /* KP1   */
            , <&key_physical_attrs 100 100  1700  300    0  0  0>   /* KP2   */
            , <&key_physical_attrs 100 100  1800  300    0  0  0>   /* KP3   */
            , <&key_physical_attrs 100 200  1900  300    0  0  0>   /* KPENT */
            /* row 4 */
            , <&key_physical_attrs 100 100     0  400    0  0  0>   /* LCTRL */
            , <&key_physical_attrs 125 100   100  400    0  0  0>   /* LALT  */
            , <&key_physical_attrs 150 100   225  400    0  0  0>   /* LGUI  */
            , <&key_physical_attrs 625 100   375  400    0  0  0>   /* SPACE */
            , <&key_physical_attrs 100 100  1000  400    0  0  0>   /* FN    */
            , <&key_physical_attrs 100 100  1100  400    0  0  0>   /* LEFT  */
            , <&key_physical_attrs 100 100  1200  400    0  0  0>   /* DOWN  */
            , <&key_physical_attrs 100 100  1300  400    0  0  0>   /* UP    */
            , <&key_physical_attrs 100 100  1400  400    0  0  0>   /* RIGHT */
            , <&key_physical_attrs 200 100  1600  400    0  0  0>   /* KP0   */
            , <&key_physical_attrs 100 100  1800  400    0  0  0>   /* KP.   */
            ;
    };

};
